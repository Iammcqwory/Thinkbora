---
const pipelineSteps = [
  {
    number: "01",
    title: "Learn",
    description: "Data analytics, AI, automation, product development. Applied from week one.",
    tag: "8 weeks"
  },
  {
    number: "02",
    title: "Build",
    description: "Real projects from Waziri clients, SMEs, and BIG portfolio companies.",
    tag: "Supervised delivery"
  },
  {
    number: "03",
    title: "Prove",
    description: "Portfolio. Case studies. Certifications. A professional profile companies can evaluate.",
    tag: "Demonstrable output"
  },
  {
    number: "04",
    title: "Place",
    description: "Top graduates connect to internships, freelance roles, partner companies, and employment.",
    tag: "The actual goal"
  }
];

const projects = [
  {
    type: "Automation",
    name: "Lead qualification system for a Nairobi SME",
    detail: "Automates scoring and outreach, replacing a manual 3-hour daily process.",
    org: "Waziri Collective"
  },
  {
    type: "Data Analytics",
    name: "Sales trend dashboard for a consumer brand",
    detail: "Weekly reporting pipeline with visualisations and anomaly alerts.",
    org: "BIG Portfolio"
  },
  {
    type: "AI Product",
    name: "WhatsApp AI agent for a media startup",
    detail: "Handles inbound subscriber queries using a trained knowledge base.",
    org: "External Startup"
  }
];

const skillExamples = [
  {
    category: "Automation Skill",
    name: "SME Lead Scoring Agent",
    description: "Packages a WhatsApp-to-CRM qualification workflow as a reusable agent skill for small business sales teams.",
    impact: "Cuts daily lead triage from hours to minutes.",
    useCase: "Sales ops, outreach, CRM cleanup"
  },
  {
    category: "Analytics Skill",
    name: "Retail KPI Dashboard Builder",
    description: "Turns weekly sales exports into clean dashboards with anomaly notes, cohort commentary, and board-ready summaries.",
    impact: "Gives founders a repeatable Monday reporting rhythm.",
    useCase: "Dashboards, investor updates, growth reviews"
  },
  {
    category: "Client Delivery Skill",
    name: "Local Services Proposal Assistant",
    description: "Helps agencies convert client briefs into scoped deliverables, timelines, risks, and pricing assumptions.",
    impact: "Improves proposal speed while keeping scope visible.",
    useCase: "Freelance teams, agencies, project leads"
  },
  {
    category: "Knowledge Skill",
    name: "African Market Research Pack",
    description: "Guides AI agents through source-backed market scans, competitor mapping, and African-context opportunity notes.",
    impact: "Makes research outputs easier to trust and reuse.",
    useCase: "Market sizing, startup validation, briefs"
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ThinkBora trains young people in data, AI, and business innovation through live client projects."
    />
    <title>ThinkBora | Skills, Projects, Careers</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="tb-root">
      <nav class="tb-nav" aria-label="Primary navigation">
        <a class="tb-logo" href="/" aria-label="ThinkBora home">Think<span>Bora</span></a>
        <ul class="tb-nav-links">
          <li><a href="#pipeline">How it works</a></li>
          <li><a href="#skills">AI skills</a></li>
          <li><a href="#audience">For learners</a></li>
          <li><a href="#companies">For companies</a></li>
        </ul>
        <a class="tb-nav-cta" href="mailto:thinkbora@waziricollectivelabs.com?subject=ThinkBora%20cohort%20application">Apply now</a>
      </nav>

      <main>
        <section class="tb-hero" aria-labelledby="hero-heading">
          <div class="tb-eyebrow">Waziri Collective Labs</div>
          <h1 id="hero-heading" class="tb-h1">Africa's AI talent<br /><em>built on real work.</em></h1>
          <div class="tb-tagline-display" aria-label="Skills, Projects, Careers">
            Skills <span class="tb-tagline-dot"></span> Projects <span class="tb-tagline-dot"></span> Careers
          </div>
          <p class="tb-sub">
            ThinkBora trains young people in data, AI, and business innovation through live client projects.
            Graduates leave with a portfolio that proves they can deliver, not just learn.
          </p>
          <div class="tb-cta-group">
            <a class="tb-btn-primary" href="mailto:thinkbora@waziricollectivelabs.com?subject=ThinkBora%20cohort%20application">Apply to the cohort</a>
            <a class="tb-btn-outline" href="mailto:thinkbora@waziricollectivelabs.com?subject=Hiring%20ThinkBora%20graduates">Hire our graduates</a>
          </div>

          <div class="tb-stat-bar" aria-label="ThinkBora highlights">
            <div class="tb-stat">
              <div class="tb-stat-num">100<span>%</span></div>
              <div class="tb-stat-label">Project-based curriculum</div>
            </div>
            <div class="tb-stat">
              <div class="tb-stat-num">4</div>
              <div class="tb-stat-label">Cohort phases</div>
            </div>
            <div class="tb-stat">
              <div class="tb-stat-num">3</div>
              <div class="tb-stat-label">Exit paths: hire, freelance, launch</div>
            </div>
          </div>
        </section>

        <section id="pipeline" class="tb-pipeline" aria-labelledby="pipeline-heading">
          <p class="tb-section-label" id="pipeline-heading">The pipeline</p>
          <div class="tb-steps">
            {
              pipelineSteps.map((step) => (
                <article class="tb-step">
                  <div class="tb-step-num">{step.number}</div>
                  <h2 class="tb-step-title">{step.title}</h2>
                  <p class="tb-step-desc">{step.description}</p>
                  <div class="tb-step-tag">{step.tag}</div>
                </article>
              ))
            }
          </div>
        </section>

        <section class="tb-proof" aria-labelledby="proof-heading">
          <div class="tb-proof-head">
            <h2 id="proof-heading" class="tb-proof-title">Projects students deliver</h2>
            <p class="tb-section-label">Real clients. Real stakes.</p>
          </div>
          <div class="tb-projects">
            {
              projects.map((project) => (
                <article class="tb-project-card">
                  <div class="tb-project-type">{project.type}</div>
                  <h3 class="tb-project-name">{project.name}</h3>
                  <p class="tb-project-detail">{project.detail}</p>
                  <div class="tb-project-org">{project.org}</div>
                </article>
              ))
            }
          </div>
        </section>

        <section id="skills" class="tb-skills" aria-labelledby="skills-heading">
          <div class="tb-skills-intro">
            <p class="tb-section-label">Reusable AI-native artifacts</p>
            <h2 id="skills-heading" class="tb-skills-title">Student work becomes installable <code>SKILL.md</code> tools.</h2>
            <p class="tb-skills-copy">
              ThinkBora graduates package real client deliverables as portable agent skills: automation scripts,
              research workflows, dashboards, and assistants that companies can inspect, reuse, and adapt.
            </p>
            <div class="tb-install-panel" aria-label="Skill installation options">
              <div>
                <span>Install targets</span>
                <strong>Claude, Cursor, Codex, agent workspaces</strong>
              </div>
              <a href="mailto:thinkbora@waziricollectivelabs.com?subject=ThinkBora%20AI%20skills%20gallery">Request the gallery</a>
            </div>
          </div>
          <div class="tb-skill-gallery">
            {
              skillExamples.map((skill) => (
                <article class="tb-skill-card">
                  <div class="tb-skill-category">{skill.category}</div>
                  <h3 class="tb-skill-name">{skill.name}</h3>
                  <p class="tb-skill-desc">{skill.description}</p>
                  <div class="tb-skill-meta">
                    <span>{skill.useCase}</span>
                    <strong>{skill.impact}</strong>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section id="audience" class="tb-audience" aria-labelledby="audience-heading">
          <p class="tb-section-label" id="audience-heading">Who ThinkBora is for</p>
          <div class="tb-audience-grid">
            <article class="tb-aud-card accent">
              <div class="tb-aud-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img">
                  <path d="M12 3.2c2.5 1.7 4.1 4.5 4.2 7.6l2.3 2.3c.3.3.4.8.2 1.2l-1.1 2.1c-.2.4-.7.6-1.1.4l-2.1-.8a8.3 8.3 0 0 1-4.8 0l-2.1.8c-.4.2-.9 0-1.1-.4l-1.1-2.1c-.2-.4-.1-.9.2-1.2l2.3-2.3C7.9 7.7 9.5 4.9 12 3.2Z" />
                  <path d="M10.2 17.5 8.8 21l3.2-1.5 3.2 1.5-1.4-3.5" />
                  <circle cx="12" cy="10" r="1.5" />
                </svg>
              </div>
              <h2 class="tb-aud-title">Young Africans ready to build</h2>
              <p class="tb-aud-desc">
                You want more than theory. Build things that matter, leave with a portfolio that speaks,
                and connect to real opportunities inside Africa's growing AI economy.
              </p>
              <a class="tb-aud-cta" href="mailto:thinkbora@waziricollectivelabs.com?subject=ThinkBora%20cohort%20application">Apply to the cohort</a>
            </article>
            <article id="companies" class="tb-aud-card">
              <div class="tb-aud-icon muted" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img">
                  <path d="M4 21V6.5c0-.8.7-1.5 1.5-1.5h7c.8 0 1.5.7 1.5 1.5V21" />
                  <path d="M14 9h4.5c.8 0 1.5.7 1.5 1.5V21" />
                  <path d="M7 9h1.5M10.5 9H12M7 12.5h1.5M10.5 12.5H12M7 16h1.5M10.5 16H12M16.5 13H18M16.5 16H18M3 21h18" />
                </svg>
              </div>
              <h2 class="tb-aud-title">Companies that need AI talent</h2>
              <p class="tb-aud-desc">
                Sponsor a cohort. Get supervised student teams working on your business challenges.
                Access a vetted pool of graduates trained on real deliverables, not hypotheticals.
              </p>
              <a class="tb-btn-outline compact" href="mailto:thinkbora@waziricollectivelabs.com?subject=ThinkBora%20partnership">Partner with us</a>
            </article>
          </div>
        </section>
      </main>

      <footer class="tb-footer">
        <div class="tb-footer-left">
          <div class="tb-footer-logo">Think<span>Bora</span> - Waziri Collective Labs</div>
          <div class="tb-footer-tagline">Skills - Projects - Careers</div>
        </div>
        <a href="mailto:thinkbora@waziricollectivelabs.com">thinkbora@waziricollectivelabs.com</a>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --color-background-primary: #f8fbf9;
    --color-surface-primary: #ffffff;
    --color-text-primary: #13201b;
    --color-text-secondary: #65736d;
    --color-border-primary: #9facaa;
    --color-border-tertiary: rgba(19, 32, 27, 0.16);
    --color-accent: #1d9e75;
    --color-accent-dark: #0f6e56;
    --color-accent-soft: #e1f5ee;
    --border-radius-lg: 8px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--color-background-primary);
    color: var(--color-text-primary);
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    margin: 0;
    font-family: "Syne", Arial, sans-serif;
    background:
      linear-gradient(90deg, rgba(29, 158, 117, 0.06) 1px, transparent 1px),
      linear-gradient(180deg, rgba(29, 158, 117, 0.04) 1px, transparent 1px),
      var(--color-background-primary);
    background-size: 88px 88px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  a {
    -webkit-tap-highlight-color: transparent;
  }
</style>

<style>
  .tb-root {
    min-height: 100vh;
    color: var(--color-text-primary);
  }

  .tb-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 2rem;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    background: rgba(248, 251, 249, 0.9);
    backdrop-filter: blur(16px);
  }

  .tb-logo {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .tb-logo span,
  .tb-footer-logo span {
    color: var(--color-accent);
  }

  .tb-nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
    padding: 0;
    margin: 0;
    list-style: none;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .tb-nav-links a {
    transition: color 160ms ease;
  }

  .tb-nav-links a:hover {
    color: var(--color-text-primary);
  }

  .tb-nav-cta,
  .tb-btn-primary,
  .tb-btn-outline,
  .tb-aud-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border-radius: 999px;
    border: 1.5px solid transparent;
    font-family: "Syne", Arial, sans-serif;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    cursor: pointer;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .tb-nav-cta,
  .tb-btn-primary,
  .tb-aud-cta {
    background: var(--color-accent);
    color: #ffffff;
  }

  .tb-nav-cta {
    padding: 8px 20px;
    font-size: 13px;
    white-space: nowrap;
  }

  .tb-btn-primary,
  .tb-btn-outline {
    padding: 14px 28px;
    font-size: 14px;
  }

  .tb-btn-outline {
    border-color: var(--color-border-primary);
    background: transparent;
    color: var(--color-text-primary);
  }

  .tb-btn-outline.compact,
  .tb-aud-cta {
    min-height: 38px;
    margin-top: 1.5rem;
    padding: 10px 20px;
    font-size: 13px;
  }

  .tb-nav-cta:hover,
  .tb-btn-primary:hover,
  .tb-btn-outline:hover,
  .tb-aud-cta:hover {
    transform: translateY(-1px);
  }

  .tb-btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-dark);
  }

  .tb-hero {
    max-width: 820px;
    padding: 5rem 2rem 4rem;
  }

  .tb-eyebrow {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 1.5rem;
    color: var(--color-accent);
    font-family: "Space Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .tb-eyebrow::before {
    display: inline-block;
    width: 24px;
    height: 1.5px;
    background: var(--color-accent);
    content: "";
  }

  .tb-h1 {
    max-width: 760px;
    margin: 0 0 1.5rem;
    color: var(--color-text-primary);
    font-size: clamp(38px, 6vw, 64px);
    font-weight: 800;
    line-height: 1;
  }

  .tb-h1 em {
    color: var(--color-accent);
    font-style: normal;
  }

  .tb-tagline-display {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 1.75rem;
    color: var(--color-text-secondary);
    font-family: "Space Mono", monospace;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .tb-tagline-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    flex: 0 0 auto;
  }

  .tb-sub {
    max-width: 560px;
    margin: 0 0 2.5rem;
    color: var(--color-text-secondary);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
  }

  .tb-cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tb-stat-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin: 3rem 0 0;
    border-top: 0.5px solid var(--color-border-tertiary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }

  .tb-stat {
    min-width: 0;
    padding: 1.5rem 2rem;
    border-right: 0.5px solid var(--color-border-tertiary);
  }

  .tb-stat:last-child {
    border-right: 0;
  }

  .tb-stat-num {
    margin-bottom: 4px;
    color: var(--color-text-primary);
    font-size: 32px;
    font-weight: 800;
    line-height: 1;
  }

  .tb-stat-num span {
    color: var(--color-accent);
  }

  .tb-stat-label {
    color: var(--color-text-secondary);
    font-family: "Space Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .tb-pipeline,
  .tb-proof,
  .tb-skills,
  .tb-audience {
    padding: 4rem 2rem;
  }

  .tb-proof,
  .tb-skills,
  .tb-audience {
    border-top: 0.5px solid var(--color-border-tertiary);
  }

  .tb-section-label {
    margin: 0 0 3rem;
    color: var(--color-text-secondary);
    font-family: "Space Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .tb-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    overflow: hidden;
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    background: rgba(255, 255, 255, 0.35);
  }

  .tb-step {
    min-width: 0;
    padding: 2rem 1.5rem;
    border-right: 0.5px solid var(--color-border-tertiary);
  }

  .tb-step:last-child {
    border-right: 0;
  }

  .tb-step-num {
    margin-bottom: 1rem;
    color: var(--color-accent);
    font-family: "Space Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .tb-step-title {
    margin: 0 0 0.75rem;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .tb-step-desc {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 13px;
    line-height: 1.6;
  }

  .tb-step-tag {
    display: inline-block;
    margin-top: 1rem;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent-dark);
    font-family: "Space Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .tb-proof-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .tb-proof-head .tb-section-label {
    margin-bottom: 0;
    text-align: right;
  }

  .tb-proof-title {
    margin: 0;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .tb-projects {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .tb-project-card,
  .tb-aud-card {
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
  }

  .tb-project-card {
    min-width: 0;
    padding: 1.5rem;
    background: var(--color-surface-primary);
  }

  .tb-project-type {
    margin-bottom: 0.75rem;
    color: var(--color-accent);
    font-family: "Space Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tb-project-name {
    margin: 0 0 0.5rem;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
  }

  .tb-project-detail {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 12px;
    line-height: 1.6;
  }

  .tb-project-org {
    margin-top: 1rem;
    color: var(--color-text-secondary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .tb-skills {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
    gap: 2rem;
    align-items: start;
  }

  .tb-skills-intro {
    position: sticky;
    top: 6.5rem;
    min-width: 0;
  }

  .tb-skills-title {
    max-width: 520px;
    margin: 0;
    font-size: 34px;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .tb-skills-title code {
    padding: 0 0.2em;
    border-radius: 6px;
    background: var(--color-accent-soft);
    color: var(--color-accent-dark);
    font-family: "Space Mono", monospace;
    font-size: 0.72em;
  }

  .tb-skills-copy {
    max-width: 520px;
    margin: 1.25rem 0 0;
    color: var(--color-text-secondary);
    font-size: 15px;
    line-height: 1.65;
  }

  .tb-install-panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 520px;
    margin-top: 1.75rem;
    padding: 1rem;
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    background: rgba(255, 255, 255, 0.55);
  }

  .tb-install-panel span,
  .tb-skill-category,
  .tb-skill-meta span {
    color: var(--color-text-secondary);
    font-family: "Space Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tb-install-panel strong {
    display: block;
    margin-top: 0.3rem;
    font-size: 13px;
    line-height: 1.35;
  }

  .tb-install-panel a {
    flex: 0 0 auto;
    padding: 9px 14px;
    border-radius: 999px;
    background: var(--color-text-primary);
    color: #ffffff;
    font-size: 12px;
    font-weight: 700;
